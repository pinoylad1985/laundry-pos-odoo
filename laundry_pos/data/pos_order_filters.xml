<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- noupdate: created on install/refresh, but not overwritten on upgrade (so UI tweaks stick). -->
    <data noupdate="1">
        <!-- Default POS Orders view = PENDINGS: open (Not Started / In Process) service
             orders, soonest due first. -->
        <record id="pos_order_filter_pendings" model="ir.filters">
            <field name="name">PENDINGS</field>
            <field name="model_id">pos.order</field>
            <!-- Scope to the POS Dashboard's Orders action only (not the global POS > Orders menu). -->
            <field name="action_id" ref="point_of_sale.action_pos_order_filtered"/>
            <field name="is_default" eval="True"/>
            <field name="sort">["laundry_due_datetime", "date_order"]</field>
            <field name="context">{'group_by': []}</field>
            <field name="domain">[('laundry_status', 'in', ['Not Started', 'In Process']), ('laundry_service_type', 'in', ['dropoff', 'dropoff_delivery', 'pickup_delivery', 'locker']), ('laundry_secondary_type', 'in', ['order'])]</field>
        </record>
    </data>
</odoo>
