<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Automations rebuilt in the module, off the Studio x_studio_* fields:
          1. Orders Status Update  — derives laundry_status from staff + folding time.
          2. Firebase Dropoff/Delivery webhook — POSTs order data on service-type/due change.
        These replace the Studio automations of the same name; once verified, DISABLE/DELETE
        the Studio originals ("Orders Status Update", "Firebase - Dropoff & Delivery webhook")
        in Settings → Technical → Automation Rules so they don't double-run on the x_studio fields.
    -->

    <!-- 1. Status: staff + folding time → laundry_status (mirrors the legacy rule). -->
    <record id="server_action_orders_status_update" model="ir.actions.server">
        <field name="name">Orders Status Update (laundry)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="usage">base_automation</field>
        <field name="state">code</field>
        <field name="code"><![CDATA[
for rec in records:
    if not rec.id:
        continue
    staff = bool(rec.laundry_staff)
    folding = bool(rec.laundry_folding_time)
    if staff and folding:
        target = 'Folded'
    elif staff:
        target = 'In Process'
    else:
        target = 'Not Started'
    if target in ('In Process', 'Folded'):
        missing = []
        if not rec.laundry_service_type:
            missing.append("Service Type is empty!")
        if not rec.laundry_due_datetime:
            missing.append("Due Datetime is empty!")
        if missing:
            raise UserError("Cannot set status to '%s':\n- %s" % (target, "\n- ".join(missing)))
    if rec.laundry_status != target:
        rec.write({'laundry_status': target})
]]></field>
    </record>

    <record id="automation_orders_status_update" model="base.automation">
        <field name="name">Orders Status Update (laundry)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('laundry_pos.field_pos_order__laundry_staff'),
            ref('laundry_pos.field_pos_order__laundry_folding_time'),
        ])]"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('server_action_orders_status_update')])]"/>
    </record>

    <!-- 2. Firebase webhook: POST order data when service type / due datetime change.
         ACTIVE on deploy — update the Firebase Cloud Function to read the new field names
         (laundry_service_type / laundry_due_datetime) so it handles the payload correctly. -->
    <record id="server_action_firebase_webhook" model="ir.actions.server">
        <field name="name">Firebase - Dropoff &amp; Delivery webhook (laundry)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="usage">base_automation</field>
        <field name="state">webhook</field>
        <field name="webhook_url">https://us-central1-pickup-delivery-c1df1.cloudfunctions.net/odooDropoffWebhook</field>
        <field name="webhook_field_ids" eval="[(6, 0, [
            ref('point_of_sale.field_pos_order__name'),
            ref('point_of_sale.field_pos_order__date_order'),
            ref('point_of_sale.field_pos_order__amount_total'),
            ref('point_of_sale.field_pos_order__partner_id'),
            ref('point_of_sale.field_pos_order__config_id'),
            ref('point_of_sale.field_pos_order__session_id'),
            ref('point_of_sale.field_pos_order__state'),
            ref('point_of_sale.field_pos_order__tracking_number'),
            ref('pos_hr.field_pos_order__cashier'),
            ref('laundry_pos.field_pos_order__laundry_service_type'),
            ref('laundry_pos.field_pos_order__laundry_due_datetime'),
        ])]"/>
    </record>

    <record id="automation_firebase_webhook" model="base.automation">
        <field name="name">Firebase - Dropoff &amp; Delivery webhook (laundry)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('laundry_pos.field_pos_order__laundry_service_type'),
            ref('laundry_pos.field_pos_order__laundry_due_datetime'),
        ])]"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('server_action_firebase_webhook')])]"/>
    </record>
</odoo>
