<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_laundry" model="ir.ui.view">
        <field name="name">product.template.form.laundry</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page string="Laundry Services" name="laundry_services">
                    <group>
                        <field
                            name="laundry_service_type_ids"
                            widget="many2many_tags"
                            string="Available for Service Types"
                            help="Tick which laundry service types apply to this product. Leave blank to show for ALL service types."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
