<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Add the laundry_* columns to the standard POS Orders list.

        NOTE: we can't hide/reposition the Studio x_studio_* columns from here — a module
        view that xpath-targets Studio-added columns fails view validation at load (the
        target lives on a sibling Studio view, not the parent). So the laundry_* columns are
        appended; hide the redundant Studio columns via the list's ⚙ column picker, or by
        editing the Studio view directly.
    -->
    <record id="view_pos_order_tree_laundry" model="ir.ui.view">
        <field name="name">pos.order.list.laundry</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <xpath expr="//list" position="inside">
                <field name="laundry_service_type" optional="show" readonly="1"/>
                <field name="laundry_secondary_type" optional="show" readonly="1"/>
                <field name="laundry_due_datetime" optional="show" readonly="1"/>
                <field name="laundry_status" optional="show" readonly="1"/>
                <field name="laundry_staff" optional="show"/>
                <field name="laundry_folding_time" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
