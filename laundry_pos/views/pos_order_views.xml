<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Add laundry columns to the standard POS Orders list:
        - laundry_service_type: the 5 modal-driven service types (read-only).
        - laundry_secondary_type: coarse Order / Payment / Refund classification (computed).
    -->
    <record id="view_pos_order_tree_laundry" model="ir.ui.view">
        <field name="name">pos.order.list.laundry</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="laundry_service_type" optional="show" readonly="1"/>
                <field name="laundry_secondary_type" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
