<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        POS Orders LIST: append the laundry_* columns (display only — editing is done on
        the form). We can't hide the Studio x_studio_* columns from a module view
        (xpath-targeting Studio-added columns fails validation) — hide them via the ⚙
        column picker or the Studio view.
    -->
    <record id="view_pos_order_tree_laundry" model="ir.ui.view">
        <field name="name">pos.order.list.laundry</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="laundry_service_type" optional="show"/>
                <field name="laundry_secondary_type" optional="show"/>
                <field name="laundry_due_datetime" optional="show"/>
                <field name="laundry_status" optional="show"/>
                <field name="laundry_staff_id" optional="show" widget="laundry_staff_pin"/>
                <field name="laundry_folding_time" optional="show" widget="laundry_folding_pin"/>
            </xpath>
        </field>
    </record>

    <!--
        POS Orders FORM: add the laundry workflow fields (editing happens here now).
        Anchored on the core partner_id field of the base form so it validates. Status /
        Service Type / Due Datetime are read-only; Staff (employee) and Folding Time editable.
    -->
    <record id="view_pos_order_form_laundry" model="ir.ui.view">
        <field name="name">pos.order.form.laundry</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="laundry_status" readonly="1"/>
                <field name="laundry_service_type" readonly="1"/>
                <field name="laundry_due_datetime" readonly="1"/>
                <field name="laundry_staff_id" widget="laundry_staff_pin"/>
                <field name="laundry_folding_time" widget="laundry_folding_pin"/>
            </xpath>
        </field>
    </record>

    <!-- PIN-gated wizard to set Staff / Folding Time (the assigned cashier's PIN). -->
    <record id="view_laundry_staff_pin_wizard_form" model="ir.ui.view">
        <field name="name">laundry.staff.pin.wizard.form</field>
        <field name="model">laundry.staff.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Set Staff / Folding Time">
                <group>
                    <field name="order_id" invisible="1"/>
                    <field name="staff_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="folding_time"/>
                    <field name="pin" password="True" placeholder="Cashier PIN"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
