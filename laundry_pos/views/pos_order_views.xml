<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Add a Payment/Adjustment dropdown to the standard POS Orders list.
        The base list isn't inline-editable, so we make it editable to allow
        picking the dropdown directly in the list. laundry_service_type is shown
        read-only (full category, incl. the 5 modal-driven types); the editable
        laundry_manual_category dropdown is limited to Payment/Adjustment.
    -->
    <record id="view_pos_order_tree_laundry" model="ir.ui.view">
        <field name="name">pos.order.list.laundry</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <xpath expr="//list" position="inside">
                <field name="laundry_service_type" optional="show" readonly="1"/>
                <field name="laundry_manual_category" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
