<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="laundry_pos.ActionHubModal">
        <Dialog title="'What would you like to do?'" size="'md'">
            <div class="d-flex flex-column gap-3 py-2">
                <button class="btn btn-primary d-flex flex-column align-items-center justify-content-center py-4"
                        t-on-click="() => this.choose('new_order')">
                    <span style="font-size:2rem;line-height:1;">🧺</span>
                    <span class="fs-4 fw-bold mt-2">NEW ORDER</span>
                    <span class="small opacity-75">Take a new laundry order</span>
                </button>

                <button class="btn btn-outline-primary d-flex flex-column align-items-center justify-content-center py-4"
                        t-on-click="() => this.choose('settle')">
                    <span style="font-size:2rem;line-height:1;">💳</span>
                    <span class="fs-4 fw-bold mt-2">SETTLE</span>
                    <span class="small opacity-75">Settle a customer's orders, invoices or due</span>
                </button>

                <button class="btn btn-outline-primary d-flex flex-column align-items-center justify-content-center py-4"
                        t-on-click="() => this.choose('list')">
                    <span style="font-size:2rem;line-height:1;">📋</span>
                    <span class="fs-4 fw-bold mt-2">LIST</span>
                    <span class="small opacity-75">Look up orders by customer</span>
                </button>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="() => this.skip()">Skip</button>
            </t>
        </Dialog>
    </t>
</templates>
