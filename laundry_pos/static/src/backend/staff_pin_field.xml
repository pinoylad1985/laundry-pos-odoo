<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="laundry_pos.StaffPinField">
        <div class="o_field_laundry_staff_pin" style="cursor: pointer; min-height: 1.5em;"
             t-on-click="() => this.open()">
            <span t-if="value" class="text-primary fw-bold"><t t-esc="value.display_name"/></span>
            <span t-else="" class="text-muted">Click to set staff…</span>
        </div>
    </t>
</templates>
