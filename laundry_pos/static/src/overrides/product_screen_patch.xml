<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//OrderSummary" position="before">
            <t t-if="laundryState and !laundryState.modalOpen">

                <!-- Setup complete: green summary bar -->
                <div t-if="laundryState.mode === 'submitted'"
                     class="d-flex align-items-start justify-content-between px-3 py-2 border-bottom gap-2"
                     style="background:#f0fdf4;flex-shrink:0;">
                    <div class="row flex-grow-1 g-2 m-0" style="font-size:0.78rem;">
                        <!-- Column 1 -->
                        <div class="col-6 px-1">
                            <div><span class="fw-semibold">Customer Type:</span> <t t-esc="_getLaundryCustomerTypeLabel()"/></div>
                            <div><span class="fw-semibold">Services:</span> <t t-esc="_getLaundryServices()"/></div>
                        </div>
                        <!-- Column 2 -->
                        <div class="col-6 px-1">
                            <div style="white-space:normal;word-break:break-word;">
                                <span class="fw-semibold">Service Type:</span> <t t-esc="_getLaundryServiceLabel()"/>
                            </div>
                            <div t-if="_getLaundryPickup()">
                                <span class="fw-semibold">Pickup:</span> <t t-esc="_getLaundryPickup()"/>
                            </div>
                            <div t-if="_getLaundryDelivery()">
                                <span class="fw-semibold"><t t-esc="_getLaundryDeliveryLabel()"/>:</span> <t t-esc="_getLaundryDelivery()"/>
                            </div>
                            <div><span class="fw-semibold">TAT:</span> <t t-esc="_getLaundryTAT()"/></div>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary flex-shrink-0"
                            t-on-click="() => this._showLaundrySetupModal(pos.getOrder(), true)">
                        Change
                    </button>
                </div>

                <!-- Setup skipped: red warning bar -->
                <div t-elif="!this._laundryIsSettlement()"
                     class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom"
                     t-att-style="'min-height:52px;cursor:pointer;flex-shrink:0;background:' + (laundryState.flash ? '#ffffff' : '#fee2e2') + ';'"
                     t-on-click="() => this._showLaundrySetupModal(pos.getOrder(), true)">
                    <span class="fw-semibold" style="color:#dc2626;font-size:0.9rem;">
                        ⚠ Tap here to complete New Order details
                    </span>
                    <button class="btn btn-sm btn-danger ms-2 flex-shrink-0"
                            t-on-click="(ev) => { ev.stopPropagation(); this._showLaundrySetupModal(pos.getOrder(), true); }">
                        Set Up Now
                    </button>
                </div>

            </t>
        </xpath>

        <!-- Lock only the PRODUCT GRID (right pane) until the New Order setup is done;
             the cart (left pane) stays usable so settlement can use it. Not shown for
             settlement orders. The navbar stays usable too. -->
        <xpath expr="//div[hasclass('rightpane')]" position="attributes">
            <attribute name="class">rightpane d-flex flex-grow-1 flex-column bg-secondary position-relative</attribute>
        </xpath>
        <xpath expr="//div[hasclass('rightpane')]" position="inside">
            <div t-if="laundryState and laundryState.mode !== 'submitted'"
                 class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center text-center"
                 style="background:rgba(255,255,255,0.92);z-index:20;">
                <i class="fa fa-lock fa-3x text-muted mb-3"/>
                <h5 class="fw-semibold text-muted px-3">Complete the New Order setup to add laundry items</h5>
            </div>
        </xpath>
    </t>
</templates>
