<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
        Inject the laundry order banner at the top of the ProductScreen left panel.
        xpath targets the leftpane div — adjust if Odoo 19 uses a different class name.
    -->
    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('leftpane')]" position="prepend">
            <LaundryOrderBanner
                mode="laundryState.mode"
                flash="laundryState.flash"
                serviceType="pos.getOrder()?.laundry_service_type || ''"
                customerType="pos.getOrder()?.laundry_customer_type || ''"
                partnerName="pos.getOrder()?.partner_id?.name || ''"
                onSetup="() => this._showLaundrySetupModal(pos.getOrder(), true)"
            />
        </xpath>
    </t>
</templates>
