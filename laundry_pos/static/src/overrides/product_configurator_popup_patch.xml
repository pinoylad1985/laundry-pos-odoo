<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ProductConfiguratorPopup" t-inherit-mode="extension">
        <!-- Note right below the "Turnaround" label, above its (locked) variants. -->
        <xpath expr="//div[hasclass('attribute_name')]" position="after">
            <div t-if="isTurnaroundAttr(attribute)" class="alert alert-info py-1 my-1 small">
                Turnaround is set by the order's schedule. Adjust the pickup and/or
                claim/delivery schedule in the New Order details to update the TAT.
            </div>
        </xpath>
        <!-- Mark the turnaround attribute so its variants are greyed / locked. -->
        <xpath expr="//div[@t-foreach='this.validAttributeLineIds']" position="attributes">
            <attribute name="t-att-class">{ 'laundry-locked-attr': isTurnaroundAttr(attribute) }</attribute>
        </xpath>

        <!-- Wash-Dry-Fold: enter the real weight; charged rounded UP to the nearest 0.5 KG. -->
        <xpath expr="//div[@t-foreach='this.validAttributeLineIds']" position="after">
            <div t-if="isLaundryWdf" class="laundry-weight mb-3" style="max-width: 18rem;">
                <label class="attribute_name mb-2 fw-bolder d-block">Actual Weight (KG)</label>
                <input type="number" step="0.1" min="0" inputmode="decimal"
                       class="form-control form-control-lg"
                       t-att-class="{ 'is-invalid': laundryKgState.invalid }"
                       placeholder="Enter actual weight in KG"
                       t-ref="laundryWeightInput"
                       t-att-value="laundryKgState.kg"
                       t-on-input="(ev) => this.onLaundryWeightInput(ev)"/>
                <small t-if="laundryKgState.invalid" class="text-danger">Actual Weight is required.</small>
            </div>
        </xpath>
    </t>
</templates>
