<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ProductConfiguratorPopup" t-inherit-mode="extension">
        <!-- Note right below the "Turnaround" label, above its (locked) variants. -->
        <xpath expr="//div[hasclass('attribute_name')]" position="after">
            <div t-if="isTurnaroundAttr(attribute)" class="alert alert-info py-1 my-1 small">
                Turnaround is set by the order's schedule. Adjust the pickup and/or
                claim/delivery schedule in the New Order details to update the TAT.
            </div>
        </xpath>
        <!-- Mark the turnaround attribute so its variants are greyed / locked. -->
        <xpath expr="//div[@t-foreach='this.validAttributeLineIds']" position="attributes">
            <attribute name="t-att-class">{ 'laundry-locked-attr': isTurnaroundAttr(attribute) }</attribute>
        </xpath>

        <!-- Wash-Dry-Fold: enter the real weight at the TOP, inline "Actual Weight: [box] KG".
             Billed rounded UP to the nearest 0.5 KG. -->
        <xpath expr="//div[@t-foreach='this.validAttributeLineIds']" position="before">
            <div t-if="isLaundryWdf" class="laundry-weight mb-3">
                <div class="d-flex align-items-center gap-2">
                    <label class="attribute_name fw-bolder mb-0 text-nowrap">Actual Weight:</label>
                    <input type="text" inputmode="decimal"
                           class="form-control form-control-lg"
                           style="width: 6rem;"
                           t-att-class="{ 'is-invalid': laundryKgState.invalid }"
                           placeholder="0.00"
                           t-ref="laundryWeightInput"
                           t-att-value="laundryKgState.kg"
                           t-on-input="(ev) => this.onLaundryWeightInput(ev)"/>
                    <span class="fw-bolder">KG</span>
                </div>
                <small t-if="laundryKgState.invalid" class="text-danger">Enter Actual Weight with 2 decimal places (e.g. 3.25).</small>
            </div>
        </xpath>

        <!-- Customer note at the BOTTOM, full width (laundry services only). -->
        <xpath expr="//div[@t-foreach='this.validAttributeLineIds']" position="after">
            <div t-if="isLaundryService" class="laundry-note mt-3">
                <label class="attribute_name fw-bolder mb-1 d-block">Note:</label>
                <input type="text" class="form-control form-control-lg w-100 fst-italic text-uppercase"
                       placeholder="Add a note (optional)"
                       t-att-value="laundryNoteState.note"
                       t-on-input="(ev) => this.onLaundryNoteInput(ev)"/>
                <small t-if="!laundryAllAttributesSelected" class="text-danger d-block mt-2">
                    Please select all options before adding.
                </small>
            </div>
        </xpath>
    </t>
</templates>
