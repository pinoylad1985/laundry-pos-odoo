<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">

        <!-- Customer name: larger + bold -->
        <xpath expr="//span[@t-esc='order.partner_id.name']" position="attributes">
            <attribute name="style">font-size: 18px; font-weight: bold;</attribute>
        </xpath>

        <!-- Phone: below the name, above the address -->
        <xpath expr="//div[@t-if='order.partner_id.name']" position="after">
            <div t-if="order.partner_id.phone">
                <span t-esc="order.partner_id.phone"/>
            </div>
        </xpath>

        <!-- Customer tags: below the address (plain text, computed server-side) -->
        <xpath expr="//div[@t-if='order.partner_id.pos_contact_address']" position="after">
            <div t-if="order.partner_id.pos_tag_names">
                <span t-esc="order.partner_id.pos_tag_names"/>
            </div>
        </xpath>

        <!-- Laundry order details: placed AFTER the centered header wrapper so they
             render full-width and flush to the far left. One blank line above and
             below; services listed one per line (first next to the header). -->
        <xpath expr="//div[hasclass('flex-column') and hasclass('align-items-center')]" position="after">
            <t t-if="laundryActive">
                <div>&#160;</div>
                <div class="laundry-details" style="font-weight:bold;">
                    <div>Customer Type: <t t-esc="laundryCustomerType"/></div>
                    <div t-if="laundryServices.length">Services: <t t-esc="laundryServices[0]"/></div>
                    <div t-foreach="laundryServices.slice(1)" t-as="s" t-key="s_index">
                        <t t-esc="s"/>
                    </div>
                    <div>TAT: <t t-esc="laundryTAT"/></div>
                    <div>Service Type: <t t-esc="laundryServiceType"/></div>
                    <div t-if="laundryPickup">Pickup: <t t-esc="laundryPickup"/></div>
                    <div t-if="laundryDelivery"><t t-esc="laundryDeliveryLabel"/>: <t t-esc="laundryDelivery"/></div>
                </div>
                <div>&#160;</div>
            </t>
        </xpath>

    </t>
</templates>
