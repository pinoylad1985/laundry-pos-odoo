<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">

        <!-- Settle + Orders, beside the product search -->
        <xpath expr="//Input" position="before">
            <!-- Desktop: text buttons -->
            <div t-if="!ui.isSmall" class="laundry-nav-buttons d-flex align-items-center gap-1 me-2">
                <button class="btn btn-light btn-lg lh-lg text-nowrap"
                        t-on-click="() => this.laundryAction('settle')">Settle</button>
                <button class="btn btn-light btn-lg lh-lg text-nowrap"
                        t-on-click="() => this.pos.navigate('TicketScreen')">Orders</button>
            </div>
            <!-- Mobile: icons (Settle = card, then Orders = book) -->
            <div t-if="ui.isSmall" class="laundry-nav-buttons d-flex align-items-center gap-1 me-1">
                <button class="btn btn-light btn-lg lh-lg" title="Settle"
                        t-on-click="() => this.laundryAction('settle')">
                    <i class="fa fa-fw fa-lg fa-credit-card"/>
                </button>
                <button class="btn btn-light btn-lg lh-lg" title="Orders"
                        t-on-click="() => this.pos.navigate('TicketScreen')">
                    <i class="fa fa-fw fa-lg fa-book"/>
                </button>
            </div>
        </xpath>

        <!-- Hide the base left-header Orders button (replaced by the buttons above) -->
        <xpath expr="//button[hasclass('orders-button')]" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>

        <!-- Hide the top-bar barcode scanner button on mobile; it stays in the ☰ menu -->
        <xpath expr="//button[@t-on-click='onClickScan']" position="attributes">
            <attribute name="t-if">isBarcodeScannerSupported() and ['ProductScreen', 'TicketScreen'].includes(this.pos.router.state.current) and !pos.config.module_pos_restaurant and !ui.isSmall</attribute>
        </xpath>

    </t>
</templates>
