<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <!-- Product name only — drop the inline (Variant)/attribute string. -->
        <xpath expr="//div[hasclass('product-name')]/span[hasclass('text-wrap')]" position="replace">
            <span class="text-wrap d-inline"><t t-esc="vals.name"/></span>
        </xpath>

        <!-- Attributes one per line, below the rate: an empty checkbox (receipt
             only) + a BOLD label + the value. -->
        <xpath expr="//ul[hasclass('info-list')]" position="after">
            <div t-if="vals.laundryAttributes and vals.laundryAttributes.length"
                 class="laundry-attrs ms-2">
                <div t-foreach="vals.laundryAttributes" t-as="a" t-key="a_index"
                     class="attribute-line" t-att-class="{ 'text-muted': a.name === 'Turnaround' }">
                    <t t-if="vals.isReceipt">&#9744; </t><b><t t-esc="a.name"/>:</b> <t t-esc="a.value"/>
                </div>
            </div>
            <!-- Wash-Dry-Fold only: write-in counts on the printed receipt. -->
            <div t-if="vals.isReceipt and vals.laundryWdf" class="laundry-attrs ms-2">
                <div class="attribute-line">&#9744; <b>Sorting count:</b> _____</div>
                <div class="attribute-line">&#9744; <b>Folding count:</b> _____</div>
            </div>
        </xpath>
    </t>
</templates>
