<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="laundry_pos.NewOrderModal">
        <Dialog title="'New Laundry Order'" size="'lg'">

            <!-- ① Who is this order for? -->
            <section class="mb-4">
                <p class="fw-semibold text-muted mb-2">1. Who is this order for?</p>
                <div class="d-flex gap-2">
                    <button
                        t-foreach="[{code:'new',label:'New Customer'},{code:'returning',label:'Returning Customer'}]"
                        t-as="ct" t-key="ct.code"
                        class="btn flex-fill py-3 fs-6"
                        t-att-class="state.customerType === ct.code ? 'btn-primary' : 'btn-outline-secondary'"
                        t-on-click="() => this.selectCustomerType(ct.code)">
                        <t t-esc="ct.label"/>
                    </button>
                </div>

                <!-- Returning customer inline search -->
                <div t-if="state.customerType === 'returning'" class="mt-3">
                    <input type="text"
                           class="form-control form-control-lg"
                           placeholder="Search by name, phone, or address..."
                           t-att-value="state.partnerQuery"
                           t-on-input="onSearchInput"
                           autofocus="autofocus"/>

                    <!-- Selected customer card -->
                    <div t-if="state.selectedPartner"
                         class="mt-2 p-3 border rounded d-flex align-items-start gap-3"
                         style="background:#f0fdf4;border-color:#86efac !important;">
                        <div class="flex-grow-1">
                            <div class="fw-bold fs-6" t-esc="state.selectedPartner.name"/>
                            <div t-if="state.selectedPartner.phone || state.selectedPartner.mobile"
                                 class="text-muted small mt-1">
                                <t t-esc="state.selectedPartner.phone || state.selectedPartner.mobile"/>
                            </div>
                            <div t-if="partnerAddress(state.selectedPartner)"
                                 class="text-muted small">
                                <t t-esc="partnerAddress(state.selectedPartner)"/>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                t-on-click="() => { state.selectedPartner = null; state.partnerQuery = ''; }">
                            Change
                        </button>
                    </div>

                    <!-- Search results -->
                    <div t-if="filteredPartners.length" class="mt-2 border rounded overflow-auto" style="max-height:220px;">
                        <div t-foreach="filteredPartners" t-as="partner" t-key="partner.id"
                             class="d-flex align-items-start gap-3 px-3 py-3 border-bottom">
                            <div class="flex-grow-1" t-on-click="() => this.pickPartner(partner)" style="cursor:pointer;">
                                <div class="fw-semibold fs-6" t-esc="partner.name"/>
                                <div t-if="partner.phone || partner.mobile" class="text-muted small mt-1">
                                    <t t-esc="partner.phone || partner.mobile"/>
                                </div>
                                <div t-if="partnerAddress(partner)" class="text-muted small">
                                    <t t-esc="partnerAddress(partner)"/>
                                </div>
                                <div t-if="partnerTags(partner).length" class="mt-1 d-flex flex-wrap gap-1">
                                    <span t-foreach="partnerTags(partner)" t-as="tag" t-key="tag.id"
                                          class="badge text-bg-secondary fw-normal">
                                        <t t-esc="tag.name"/>
                                    </span>
                                </div>
                            </div>
                            <button class="btn btn-sm btn-outline-primary flex-shrink-0 mt-1"
                                    t-on-click="(ev) => { ev.stopPropagation(); this.editPartner(partner); }">
                                Edit Details
                            </button>
                        </div>
                    </div>

                    <div t-if="showNoResults" class="mt-2 text-muted small text-center py-2">
                        No customers found
                    </div>
                </div>
            </section>

            <!-- ② Select Service Type (appears after customer type chosen) -->
            <section t-if="state.customerType" class="mb-4">
                <p class="fw-semibold text-muted mb-2">2. Select Service Type</p>
                <div class="d-flex flex-column gap-2">
                    <button t-foreach="serviceTypes" t-as="st" t-key="st.code"
                            class="btn text-start py-3 px-4 fs-6"
                            t-att-class="state.serviceType === st.code ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.selectServiceType(st.code)">
                        <t t-esc="st.label"/>
                    </button>
                </div>
            </section>

            <!-- ③ Select Services (multi-select, appears after service type chosen) -->
            <section t-if="state.serviceType" class="mb-4">
                <p class="fw-semibold text-muted mb-2">3. Select Services</p>
                <div class="row g-2">
                    <div t-foreach="services" t-as="svc" t-key="svc.code" class="col-6">
                        <button class="btn w-100 py-3 fs-6 position-relative"
                                t-att-class="isServiceSelected(svc.code) ? 'btn-primary' : 'btn-outline-secondary'"
                                t-on-click="() => this.toggleService(svc.code)">
                            <t t-esc="svc.label"/>
                            <!-- Indicator: details available / details filled -->
                            <span t-if="isServiceSelected(svc.code) &amp;&amp; instructionFields(svc.code).length"
                                  class="badge position-absolute top-0 end-0 translate-middle-y me-1"
                                  t-att-class="hasInstructions(svc.code) ? 'text-bg-light' : 'text-bg-warning'">
                                <t t-esc="hasInstructions(svc.code) ? '✓' : '⚙'"/>
                            </span>
                        </button>
                    </div>
                </div>

                <!-- Expandable instruction panels — one per selected service, collapsed by default -->
                <div class="mt-2 d-flex flex-column gap-2">
                    <div t-foreach="selectedServices" t-as="code" t-key="code"
                         class="border rounded">
                        <!-- Header -->
                        <button type="button"
                                class="btn w-100 d-flex align-items-center justify-content-between px-3 py-2 text-start"
                                t-on-click="() => this.toggleExpand(code)">
                            <span class="fw-semibold">
                                <t t-esc="isExpanded(code) ? '▾' : '▸'"/>
                                <t t-esc="' ' + servicesByCode[code]"/> details
                                <span t-if="hasInstructions(code)" class="badge text-bg-success ms-1">set</span>
                            </span>
                        </button>

                        <!-- Body -->
                        <div t-if="isExpanded(code)" class="px-3 pb-3 pt-1 border-top">
                            <div t-foreach="instructionFields(code)" t-as="field" t-key="field.key" class="mb-3">
                                <label class="form-label fw-semibold small text-muted mb-1">
                                    <t t-esc="field.label"/>
                                    <span t-if="field.attr" class="badge text-bg-light ms-1" title="Pre-selects a product variant">variant</span>
                                </label>

                                <!-- Text field (e.g. Press Instructions) -->
                                <input t-if="field.type === 'text'" type="text"
                                       class="form-control"
                                       placeholder="Optional notes..."
                                       t-att-value="getInstr(code, field.key)"
                                       t-on-input="(ev) => this.onInstrInput(code, field.key, ev)"/>

                                <!-- Pill options (single-select) -->
                                <div t-else="" class="d-flex flex-wrap gap-1">
                                    <button t-foreach="field.options" t-as="opt" t-key="opt.value"
                                            type="button" class="btn btn-sm"
                                            t-att-class="getInstr(code, field.key) === opt.value ? 'btn-primary' : 'btn-outline-secondary'"
                                            t-on-click="() => this.setInstr(code, field.key, opt.value)">
                                        <t t-esc="opt.label"/>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ④ Schedule + Turnaround (appears after services selected, not for self_service) -->
            <section t-if="hasAnyService &amp;&amp; state.serviceType !== 'self_service'" class="mb-2">
                <p class="fw-semibold text-muted mb-3">4. Schedule</p>

                <!-- Drop-off: Claim date/time (6 AM – 3 AM) -->
                <div t-if="state.serviceType === 'dropoff'" class="mb-3">
                    <label class="form-label fw-semibold small text-muted">
                        Claim Date &amp; Time <span class="text-danger">*</span>
                    </label>
                    <div class="d-flex gap-1 mb-2">
                        <button t-foreach="quickDates" t-as="qd" t-key="qd.value"
                                class="btn btn-sm flex-grow-1"
                                t-att-class="state.claimDate === qd.value ? 'btn-primary' : 'btn-outline-secondary'"
                                t-on-click="() => this.setDate('claimDate', qd.value)">
                            <t t-esc="qd.label"/>
                        </button>
                        <div class="position-relative flex-shrink-0">
                            <button class="btn btn-sm btn-outline-secondary px-2">📅</button>
                            <input type="date" class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                   style="cursor:pointer;" t-model="state.claimDate"/>
                        </div>
                    </div>
                    <t t-call="laundry_pos.HourPills">
                        <t t-set="kind" t-value="'claim'"/>
                        <t t-set="field" t-value="'claimHour'"/>
                        <t t-set="selected" t-value="state.claimHour"/>
                    </t>
                </div>

                <!-- Drop-off &amp; Delivery: Delivery date/time -->
                <div t-if="state.serviceType === 'dropoff_delivery'" class="mb-3">
                    <label class="form-label fw-semibold small text-muted">
                        Delivery Date &amp; Time <span class="text-danger">*</span>
                    </label>
                    <div class="d-flex gap-1 mb-2">
                        <button t-foreach="quickDates" t-as="qd" t-key="qd.value"
                                class="btn btn-sm flex-grow-1"
                                t-att-class="state.deliveryDate === qd.value ? 'btn-primary' : 'btn-outline-secondary'"
                                t-on-click="() => this.setDate('deliveryDate', qd.value)">
                            <t t-esc="qd.label"/>
                        </button>
                        <div class="position-relative flex-shrink-0">
                            <button class="btn btn-sm btn-outline-secondary px-2">📅</button>
                            <input type="date" class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                   style="cursor:pointer;" t-model="state.deliveryDate"/>
                        </div>
                    </div>
                    <t t-call="laundry_pos.HourPills">
                        <t t-set="kind" t-value="'delivery'"/>
                        <t t-set="field" t-value="'deliveryHour'"/>
                        <t t-set="selected" t-value="state.deliveryHour"/>
                    </t>
                </div>

                <!-- Pickup &amp; Delivery / Locker: Pickup + Delivery -->
                <t t-if="state.serviceType === 'pickup_delivery' || state.serviceType === 'locker'">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">
                            Pickup Date &amp; Time <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-1 mb-2">
                            <button t-foreach="quickDates" t-as="qd" t-key="qd.value"
                                    class="btn btn-sm flex-grow-1"
                                    t-att-class="state.pickupDate === qd.value ? 'btn-primary' : 'btn-outline-secondary'"
                                    t-on-click="() => this.setDate('pickupDate', qd.value)">
                                <t t-esc="qd.label"/>
                            </button>
                            <div class="position-relative flex-shrink-0">
                                <button class="btn btn-sm btn-outline-secondary px-2">📅</button>
                                <input type="date" class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                       style="cursor:pointer;" t-model="state.pickupDate"/>
                            </div>
                        </div>
                        <t t-call="laundry_pos.HourPills">
                            <t t-set="kind" t-value="'pickup'"/>
                            <t t-set="field" t-value="'pickupHour'"/>
                            <t t-set="selected" t-value="state.pickupHour"/>
                        </t>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">
                            Delivery Date &amp; Time <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-1 mb-2">
                            <button t-foreach="quickDates" t-as="qd" t-key="qd.value"
                                    class="btn btn-sm flex-grow-1"
                                    t-att-class="state.pdDelDate === qd.value ? 'btn-primary' : 'btn-outline-secondary'"
                                    t-on-click="() => this.setDate('pdDelDate', qd.value)">
                                <t t-esc="qd.label"/>
                            </button>
                            <div class="position-relative flex-shrink-0">
                                <button class="btn btn-sm btn-outline-secondary px-2">📅</button>
                                <input type="date" class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                       style="cursor:pointer;" t-model="state.pdDelDate"/>
                            </div>
                        </div>
                        <t t-call="laundry_pos.HourPills">
                            <t t-set="kind" t-value="'delivery'"/>
                            <t t-set="field" t-value="'pdDelHour'"/>
                            <t t-set="selected" t-value="state.pdDelHour"/>
                        </t>
                    </div>
                </t>

                <!-- Turnaround pills (auto-calculated, display only) -->
                <p class="fw-semibold text-muted mb-2 mt-3">Turnaround</p>
                <div class="d-flex gap-2">
                    <div class="flex-fill py-3 px-3 rounded border text-center"
                         t-att-class="turnaroundType === 'express' ? 'bg-primary text-white border-primary' : 'bg-light text-muted'">
                        <div class="fw-bold">⚡ Express</div>
                        <div class="small mt-1" t-esc="expressLabel"/>
                    </div>
                    <div class="flex-fill py-3 px-3 rounded border text-center"
                         t-att-class="turnaroundType === 'regular' ? 'bg-primary text-white border-primary' : 'bg-light text-muted'">
                        <div class="fw-bold">🕐 Regular</div>
                        <div class="small mt-1" t-esc="regularLabel"/>
                    </div>
                </div>
                <div t-if="turnaroundError" class="mt-2 text-danger small fw-semibold" t-esc="turnaroundError"/>
            </section>

            <t t-set-slot="footer">
                <button class="btn btn-light me-auto" t-on-click="skip">
                    Skip for now
                </button>
                <button class="btn btn-primary px-4"
                        t-att-disabled="!canConfirm"
                        t-on-click="confirm">
                    Continue →
                </button>
            </t>

        </Dialog>
    </t>

    <!--
        Reusable hour picker — two columns of 12 pills.
        Caller sets: kind ('claim'|'pickup'|'delivery'), field (state key), selected (current value).
    -->
    <t t-name="laundry_pos.HourPills">
        <div class="d-flex gap-2">
            <div class="d-flex flex-column gap-1 flex-fill">
                <button t-foreach="hoursAM" t-as="hr" t-key="hr.value"
                        type="button" class="btn btn-sm"
                        t-att-disabled="isHourDisabled(kind, hr.h)"
                        t-att-class="isHourDisabled(kind, hr.h) ? 'btn-light text-muted disabled' : (selected === hr.value ? 'btn-primary' : 'btn-outline-secondary')"
                        t-on-click="() => this.setHour(field, hr.value)">
                    <t t-esc="hr.label"/>
                </button>
            </div>
            <div class="d-flex flex-column gap-1 flex-fill">
                <button t-foreach="hoursPM" t-as="hr" t-key="hr.value"
                        type="button" class="btn btn-sm"
                        t-att-disabled="isHourDisabled(kind, hr.h)"
                        t-att-class="isHourDisabled(kind, hr.h) ? 'btn-light text-muted disabled' : (selected === hr.value ? 'btn-primary' : 'btn-outline-secondary')"
                        t-on-click="() => this.setHour(field, hr.value)">
                    <t t-esc="hr.label"/>
                </button>
            </div>
        </div>
    </t>
</templates>
