<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="laundry_pos.LaundryOrderBanner">

        <!-- Setup complete: show summary with Change button -->
        <div t-if="props.mode === 'submitted'"
             class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom"
             style="background:#f0fdf4;min-height:52px;">
            <div class="d-flex flex-column gap-1">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-primary" t-esc="serviceLabel"/>
                    <span class="text-muted" style="font-size:0.8rem;">·</span>
                    <span class="fw-semibold" style="font-size:0.9rem;" t-esc="customerLabel"/>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="() => props.onSetup()">
                Change
            </button>
        </div>

        <!-- Setup skipped: red warning, full area is a tap target -->
        <div t-elif="props.mode === 'skipped'"
             class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom"
             t-att-style="'min-height:52px;cursor:pointer;' + (props.flash ? 'background:#ffffff;transition:none;' : 'background:#fee2e2;transition:background 0.6s ease;')"
             t-on-click="() => props.onSetup()">
            <span class="fw-semibold" style="color:#dc2626;font-size:0.9rem;">
                ⚠ Tap here to complete New Order details
            </span>
            <button class="btn btn-sm btn-danger ms-2 flex-shrink-0"
                    t-on-click.stop="() => props.onSetup()">
                Set Up Now
            </button>
        </div>

    </t>
</templates>
